import wollok.game.*
import objects.*
import perros.*
import globo.*
import chillis.*
import comidas.*
import contador.*

describe "Testeos del cursor" {
	test "El cursor empieza sin comida"  {
        assert.equals(null, cursor.comidaActual())		
	}
	
	test "tomarComida selecciona la comida correctamente "{
         const comida = new Comida(nombre = "pizza" , posicionInicial = game.at(1,1))
         cursor.tomarComida(comida)
         assert.equals(comida, cursor.comidaActual())
    }
    test "Actualizar la posicion si mueve la comida tomada" {
         const comida = new Comida(nombre = "pizza", posicionInicial = game.at(1,1))
         cursor.tomarComida(comida)
         cursor.position(game.at(2,3))
         assert.equals(game.at(2,3), comida.position())
}
    
 
}

describe "Testeos Perros"{
	
	test "El perro no empieza con comida asignada"{
		const perro = new Perro(nombre = "chilli")
		assert.equals(null, perro.comidaDeseada())
	}
	test "El estado al crearse es normal"{
		const perro = new Perro(nombre = "chilli")
		assert.equals(perro.estado(), "normal")
	}
	test "El perro se pone feliz si come algo no picante"{
		const perro = new Perro(nombre = "chilli")					
		const pizza = new Comida (nombre = "pizza" , posicionInicial = game.at(1,1))
		perro.comidaDeseada(pizza)
		perro.comer()
		
		assert.equals(perro.estado(), "feliz")
		
	}
	test "El perro se pone rojo al comer picante"{
		const perro = new Perro(nombre = "chilli")					
		const aji = new ComidaPicante (nombre = "aji" , posicionInicial = game.at(1,1))
		perro.comidaDeseada(aji)
		perro.comer()
		
		assert.equals(perro.estado(), "rojo")
		
	}
	
	
}
describe "Testeo Comidas"{
	test "Comida vuelve al inicio al soltarla" {
    	const comida = new Comida(nombre = "pizza", posicionInicial = game.at(1,1))
    	comida.moverA(game.at(3,3))
    	comida.volverAlInicio()
    	assert.equals(game.at(1,1), comida.position())
	}
	test "Comida picante devuelve true en esPicante" {
  		const aji = new ComidaPicante(nombre = "aji", posicionInicial = game.at(1,1))
        assert.that(aji.esPicante())
	}
	test "Comida normal devuelve false en esPicante" {
    	const pizza = new Comida(nombre = "pizza", posicionInicial = game.at(1,1))
    	assert.notThat(pizza.esPicante())
	}
	
}

describe "Testeo del Contador de Puntos"{
	test "Los puntos empiezan en 0" {
    	assert.equals(0, contador.puntos())
    	}
	test "Se incrementan puntos correctamente" {
    	contador.incrementar_puntos()
    	assert.equals(1, contador.puntos())
    }
    test "Se decrementan puntos correctamente" {
    	contador.decrementar_puntos()
   		assert.equals(-1, contador.puntos())
    }
    
}

describe "Testeo del Timer"{
 	test "el timer empieza en cero"{
		assert.equals(timer.tiempo(), 0)
	}
	test "Incrementa el tiempo" {
    	timer.incrementarTiempo()
    	assert.equals(1, timer.tiempo())
}
	
 }
 
 
describe "Testeos juego"{
	test "Comida aleatoria es una comida" {
  		const comida = juego.comidaAleatoria()
    	assert.that(juego.comidas().contains(comida))
	}
    test "perro aleatorio es un perro" {
           const p = juego.perroAleatorio()
           assert.that(juego.perros().contains(p))
    }
   
    

}
    
 

	
	


	



	